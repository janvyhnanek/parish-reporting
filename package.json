{
  "name": "parish-reporting",
  "version": "1.0.0",
  "description": "Metadata-driven reporting platform for configurable dashboards over heterogeneous data sources.",
  "type": "module",
  "main": "server/index.ts",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite --host 0.0.0.0",
    "build": "tsc --noEmit && vite build",
    "start": "tsx server/index.ts",
    "test": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/janvyhnanek/parish-reporting.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/janvyhnanek/parish-reporting/issues"
  },
  "homepage": "https://github.com/janvyhnanek/parish-reporting#readme",
  "dependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "csv-parse": "^7.0.1",
    "echarts": "^6.1.0",
    "echarts-for-react": "^3.0.6",
    "express": "^5.2.1",
    "fast-xml-parser": "^5.10.0",
    "jszip": "^3.10.1",
    "lucide-react": "^1.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "zod": "^4.4.3"
  }
}
